{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shinden Story Chapter",
  "type": "object",
  "required": ["chapterId", "chapterTitle", "season", "timeOfDay", "startSequence"],
  "properties": {
    "chapterId": { "type": "integer", "minimum": 1 },
    "chapterTitle": { "type": "string" },
    "season": { "type": "string" },
    "timeOfDay": { "type": "string" },
    "startSequence": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "effects": {
      "type": "object",
      "properties": {
        "realityEgo": { "type": "number" },
        "fantasySynchro": { "type": "number" },
        "brainErosion": { "type": "number" }
      },
      "additionalProperties": true
    },
    "event": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "enum": [
            "dialogue",
            "choice",
            "set_scene",
            "camera",
            "spawn_collectibles",
            "require_collectibles",
            "trigger_minigame",
            "effect",
            "set_flag",
            "ending_check",
            "ending"
          ]
        },
        "speaker": { "type": "string" },
        "text": { "type": "string" },
        "cameraAngleId": { "type": "string" },
        "next": { "type": "string" },
        "effects": { "$ref": "#/$defs/effects" },
        "successEffects": { "$ref": "#/$defs/effects" },
        "failEffects": { "$ref": "#/$defs/effects" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text", "next"],
            "properties": {
              "text": { "type": "string" },
              "next": { "type": "string" },
              "effects": { "$ref": "#/$defs/effects" }
            }
          }
        }
      },
      "additionalProperties": true
    }
  }
}
