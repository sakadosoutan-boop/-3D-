      "endingId": "ED3_GAMEOVER"
    },
    {
      "id": "seq_641_ed4",
      "type": "dialogue",
      "speaker": "語り",
      "text": "帰る道を前に、秀頼は振り返った。御簾の内へ入ると、現代の音は美しく遠ざかった。",
      "next": "seq_642_ed4_end",
