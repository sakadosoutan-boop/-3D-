    {
      "id": "seq_611_ed1",
      "type": "dialogue",
      "speaker": "語り",
      "text": "秀頼は現代の教室で目を覚ました。机には白い短冊が一枚だけ残り、窓の外をカモメが横切る。",
      "next": "seq_612_ed1_line",
      "se": "bell",
      "stage": {
        "purpleCord": true,
        "seagull": true
      }
    },
    {
      "id": "seq_612_ed1_line",
      "type": "dialogue",
      "speaker": "秀頼",
      "text": "御簾って、ただ隠すためのものじゃないんだな。今度、ちゃんと教えてくれないか。",
      "next": "seq_613_ed1_end"
    },
    {
      "id": "seq_613_ed1_end",
      "type": "ending",
      "endingId": "ED1_TRUE"
    },
    {
      "id": "seq_621_ed2",
      "type": "dialogue",
      "speaker": "語り",
      "text": "秀頼は現実へ戻った。古典の点は上がった。けれど、小萩の声だけが、朝の光の中で薄れていく。",
      "next": "seq_622_ed2_end"
    },
    {
      "id": "seq_622_ed2_end",
      "type": "ending",
      "endingId": "ED2_NORMAL"
    },
    {
      "id": "seq_631_ed3",
      "type": "dialogue",
      "speaker": "語り",
      "text": "灯火は消え、御簾の向こうの声は黒い線になった。言葉のない夜だけが、廂に残った。",
      "next": "seq_632_ed3_end"
    },
    {
      "id": "seq_632_ed3_end",
